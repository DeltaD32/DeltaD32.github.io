# =====================================================================
# BMW Supplier XChange Site — Apache .htaccess
# Mirrors nginx.conf behavior for Apache 2.4 + mod_rewrite,
# mod_headers, mod_expires, mod_deflate, mod_mime.
# =====================================================================

Options -Indexes

# ─── Gzip / Deflate compression ──────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE font/woff
    AddOutputFilterByType DEFLATE font/woff2
    AddOutputFilterByType DEFLATE application/font-woff
    AddOutputFilterByType DEFLATE application/font-woff2
    DeflateCompressionLevel 6
    # Vary header for proxies
    Header append Vary Accept-Encoding
</IfModule>

# ─── Security headers ────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# ─── URL rewriting ───────────────────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Health-check endpoint — return 200 with plain text body
    RewriteRule ^health$ - [R=200,L,T=text/plain]

    # Deny hidden files (dot-files)
    RewriteRule (^|/)\. - [F,L]

    # Extensionless URLs: try exact file, then .html, then directory, else 404
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.html -f
    RewriteRule ^(.+?)/?$ $1.html [L]
</IfModule>

# ─── Custom 404 page ─────────────────────────────────────────────────
ErrorDocument 404 /404.html

# ─── Cache-Control / Expires ─────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On

    # Images — 1 year + immutable
    <FilesMatch "\.(jpg|jpeg|png|gif|ico|svg|webp)$">
        ExpiresDefault "access plus 1 year"
        Header set Cache-Control "public, immutable"
    </FilesMatch>

    # CSS and JavaScript — 1 year + immutable
    <FilesMatch "\.(css|js)$">
        ExpiresDefault "access plus 1 year"
        Header set Cache-Control "public, immutable"
    </FilesMatch>

    # Web fonts — 1 year + immutable
    <FilesMatch "\.(woff|woff2|ttf|otf|eot)$">
        ExpiresDefault "access plus 1 year"
        Header set Cache-Control "public, immutable"
    </FilesMatch>

    # Video — 1 year + immutable
    <FilesMatch "\.(mp4|webm|ogg)$">
        ExpiresDefault "access plus 1 year"
        Header set Cache-Control "public, immutable"
    </FilesMatch>

    # JSON and XML data files — 1 hour, must-revalidate
    <FilesMatch "\.(json|xml)$">
        ExpiresDefault "access plus 1 hour"
        Header set Cache-Control "public, must-revalidate"
    </FilesMatch>

    # HTML — 1 hour, must-revalidate
    <FilesMatch "\.html$">
        ExpiresDefault "access plus 1 hour"
        Header set Cache-Control "public, must-revalidate"
    </FilesMatch>
</IfModule>
